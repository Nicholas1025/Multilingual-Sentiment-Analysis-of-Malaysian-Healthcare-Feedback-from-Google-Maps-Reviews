# ─── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# ─── Secrets ────────────────────────────────────────────────────────
.env
!.env.example

# ─── Data files (too large for git, regenerable from scrapers) ──────
