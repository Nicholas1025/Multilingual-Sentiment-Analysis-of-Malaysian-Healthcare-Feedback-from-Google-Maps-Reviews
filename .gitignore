models/*.pkl
models/*.npz
models/transformer/
models/*.txt

# ─── Generated artefacts ────────────────────────────────────────────
*.png
*.svg
Report/*.docx
Report/figures/

# ─── Browser / scraping leftovers ───────────────────────────────────
chrome_profile/
downloaded_files/

# ─── OS / editor ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
